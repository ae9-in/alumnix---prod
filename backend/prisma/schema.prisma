generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  HIRED
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  name           String
  passwordHash   String
  role           UserRole @default(USER)
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile        Profile?
  posts          Post[]
  connectionsOut Connection[] @relation("ConnectionsFrom")
  connectionsIn  Connection[] @relation("ConnectionsTo")
  applications   Application[]
  notifications  Notification[]
}

model Profile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  headline    String?
  bio         String?
  location    String?
  company     String?
  title       String?
  batchYear   Int?
  skillsJson  String   @default("[]")
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  authorId  String   @db.ObjectId
  content   String
  createdAt DateTime @default(now())

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Gig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  company     String
  location    String
  type        String
  salaryBand  String?
  description String
  tagsJson    String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  startsAt    DateTime
  mode        String
  location    String?
  description String
  attendees   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Connection {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fromId    String   @db.ObjectId
  toId      String   @db.ObjectId
  createdAt DateTime @default(now())

  from      User     @relation("ConnectionsFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        User     @relation("ConnectionsTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

model Application {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  userId    String            @db.ObjectId
  gigId     String?           @db.ObjectId
  company   String
  roleTitle String
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}
