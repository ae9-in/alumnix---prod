{
  "name": "alumnix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=../backend/prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate --schema=../backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=../backend/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} ../backend/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "gsap": "^3.14.2",
    "lucide-react": "^0.460.0",
    "mongodb": "^7.1.1",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "unicornstudio-react": "^2.1.4-1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.16.1",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
